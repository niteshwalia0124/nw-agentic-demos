# Required
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional — Web search
SERPAPI_KEY=your-serpapi-key-here

# Optional — Weather tool
OPENWEATHERMAP_API_KEY=your-openweathermap-key-here

# Optional — Max ReAct iterations
MAX_ITERATIONS=10

# Optional — log level (DEBUG, INFO, WARNING)
LOG_LEVEL=INFO
