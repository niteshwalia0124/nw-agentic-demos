# Required
GOOGLE_API_KEY=your-gemini-api-key-here
SERPAPI_KEY=your-serpapi-key-here

# Optional — Research pipeline settings
MAX_SUB_QUERIES=5
MAX_SEARCH_RESULTS=3
MAX_REVIEW_ITERATIONS=2

# Optional — Output format (markdown, html, json)
REPORT_FORMAT=markdown

# Optional — Directory to save generated reports
REPORTS_DIR=./reports

# Optional — log level (DEBUG, INFO, WARNING)
LOG_LEVEL=INFO
