# ── Required ─────────────────────────────────────────────────────────
# Gemini API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# ── MCP Server URLs ──────────────────────────────────────────────────
# Override these when MCP servers are deployed to Cloud Run.
# Defaults to http://localhost:8080/mcp for local development.
RISK_MCP_URL=http://localhost:8080/mcp
POLICY_MCP_URL=http://localhost:8080/mcp
CLAIMS_MCP_URL=http://localhost:8080/mcp
COMPLIANCE_MCP_URL=http://localhost:8080/mcp
